rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Match any document in the 'users' collection
    match /users/{userId} {
      // Anyone can read user profiles (needed for the Electricians directory)
      allow read: if true;
      // Only the authenticated user can create/update their own document
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Match any document in the 'bookings' collection
    match /bookings/{bookingId} {
      // Users can only read/write bookings where they are the client or provider
      // For now, require the user to be authenticated to read/write
      allow read, write: if request.auth != null;
    }

    // Default rule for all other collections (Require Authentication)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
